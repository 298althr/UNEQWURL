# ──── Database (Supabase/Neon/etc.) ────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ──── Backblaze B2 ────
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_BUCKET_ID=
# Friendly download URL (e.g. https://f003.backblazeb2.com/file/your-bucket-name)
B2_DOWNLOAD_URL=

# ──── Server ────
PORT=3100

# ──── CORS ────
# Comma-separated list of allowed origins (your Vercel app URL)
CORS_ORIGINS=https://your-app.vercel.app
