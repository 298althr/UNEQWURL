"use client";

import { useEffect, useState } from "react";
import Link from "next/link";
import BottomNav from "@/components/BottomNav";
import ProfileDropdown from "@/components/ProfileDropdown";
import type { SongListItem } from "@/lib/types";
import SessionDetailModal, { type SessionDetail } from "@/components/SessionDetailModal";
import { Music, Radio, Mic, Shield, Cloud, Download } from "lucide-react";

type UserSubmission = {
  id: string;
  song_title: string;
  score: number;
  submitted_at: string;
  settings: {
    eq298: number;
  };
};

type UserSession = {
  id: string;
  song_title: string;
  session_start: string;
  session_end: string;
  average_298eq: number;
  final_settings: {
    eq298: number;
  };
  ab_toggles: number;
  created_at: string;
};

type UserUploadItem = {
  id: string;
  upload_type: "music" | "podcast" | "voice";
  source: "upload" | "youtube";
  youtube_url: string | null;
  original_filename: string;
  title: string;
  artist: string;
  album: string | null;
  genre: string | null;
  file_size_bytes: number;
  file_url: string;
  created_at: string;
};

export default function SongsPage() {
  const [songs, setSongs] = useState<SongListItem[]>([]);
  const [submissions, setSubmissions] = useState<UserSubmission[]>([]);
  const [sessions, setSessions] = useState<UserSession[]>([]);
  const [selectedSession, setSelectedSession] = useState<SessionDetail | null>(null);
  const [uploads, setUploads] = useState<UserUploadItem[]>([]);
  const [loadingSongs, setLoadingSongs] = useState(true);
  const [loadingExtras, setLoadingExtras] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [isAdmin, setIsAdmin] = useState(false);

  // Load songs immediately (critical path)
  useEffect(() => {
    fetch("/api/songs")
      .then((r) => {
        if (!r.ok) throw new Error("Failed to load songs");
        return r.json();
      })
      .then((data) => {
        setSongs(data);
      })
      .catch((err) => {
        console.error(err);
        setError("Could not load songs.");
      })
      .finally(() => setLoadingSongs(false));
  }, []);

  // Load secondary data in background
  useEffect(() => {
    Promise.all([
      fetch("/api/submissions").then((r) => (r.ok ? r.json() : [])),
      fetch("/api/session-analytics").then((r) => (r.ok ? r.json() : [])),
      fetch("/api/uploads").then((r) => (r.ok ? r.json() : [])),
      fetch("/api/auth/me").then((r) => (r.ok ? r.json() : null)),
    ])
      .then(([submissionsData, sessionsData, uploadsData, meData]) => {
        setSubmissions(submissionsData.slice(0, 5));
        setSessions(sessionsData.slice(0, 5));
        setUploads(uploadsData);
        if (meData?.role === "admin") setIsAdmin(true);
      })
      .catch((err) => console.error("Background load failed:", err))
      .finally(() => setLoadingExtras(false));
  }, []);

  // Map uploads to demo categories
  const findUploadByType = (type: "music" | "podcast" | "voice") =>
    uploads.find((u) => u.upload_type === type) || null;

  const musicUpload = findUploadByType("music");
  const podcastUpload = findUploadByType("podcast");
  const voiceUpload = findUploadByType("voice");

  return (
    <div className="container mx-auto min-h-screen">
      {/* Header */}
      <header className="header header-with-profile">
        <div className="logo">
          <div className="logo-mark">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <span className="logo-text">298<span>EQ</span></span>
        </div>
        <div className="flex items-center gap-3">
          {isAdmin && (
            <Link
              href="/admin"
              className="flex items-center gap-1.5 rounded-lg border border-accent/30 bg-accent/10 px-3 py-1.5 text-xs font-semibold text-accent hover:bg-accent/20 transition-colors"
            >
              <Shield size={14} />
              Admin Panel
            </Link>
          )}
          <ProfileDropdown />
        </div>
      </header>

      {/* Hero */}
      <section className="hero">
        <div
          className="hero-bg-image"
          style={{
            backgroundImage:
              "url('https://images.unsplash.com/photo-1670507578828-76b64166f01d?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D')",
          }}
        />
        <div className="hero-content">
          <div className="hero-badge">Audio Enhancement Studio</div>
          <h1>Hear What <span className="gradient-text">Better Audio</span> Sounds Like</h1>
          <p>
            Compare raw and enhanced sound in real time. Adjust Low, Mid, High, and the 298EQ
            enhancement engine while listening to music, podcasts, and voice recordings.
          </p>
        </div>
      </section>

      {/* Loading & Error */}
      {loadingSongs && (
        <div className="dashboard-loading">
          <div className="loading-spinner" />
          <p>Initialising demo environment...</p>
        </div>
      )}
      {error && (
        <div style={{ padding: "24px 0", textAlign: "center", fontSize: "13px", color: "#f87171" }}>
          {error}
        </div>
      )}

      {/* Demo Source Cards — powered by your uploads */}
      {!loadingSongs && !error && (
        <>
          <div className="sources">
            {musicUpload ? (
              <div className="source-card" style={{ position: "relative" }}>
                <Link href={`/room/${musicUpload.id}`} style={{ display: "block", textDecoration: "none" }}>
                  <div
                    className="source-card-bg"
                    style={{
                      backgroundImage: "url('https://images.unsplash.com/photo-1559120721-872e938d8793?q=80&w=1170&auto=format&fit=crop')",
                      opacity: 0.9,
                    }}
                  />
                  <div className="source-icon"><Music size={16} /></div>
                  <div className="source-title">Music Demo</div>
                  <div className="source-subtitle">{musicUpload.title} · {musicUpload.artist}</div>
                </Link>
                <div style={{ position: "absolute", top: 8, right: 8, display: "flex", gap: 4 }}>
                  {musicUpload.source === "youtube" && (
                    <Cloud size={14} className="text-accent" />
                  )}
                  <a
                    href={musicUpload.file_url}
                    download
                    title="Download file"
                    style={{ color: "var(--muted)" }}
                    onClick={(e) => e.stopPropagation()}
                  >
                    <Download size={14} />
                  </a>
                </div>
              </div>
            ) : (
              <Link href="/uploads" className="source-card" style={{ opacity: 0.6 }}>
                <div
                  className="source-card-bg"
                  style={{
                    backgroundImage: "url('https://images.unsplash.com/photo-1559120721-872e938d8793?q=80&w=1170&auto=format&fit=crop')",
                    opacity: 0.4,
                  }}
                />
                <div className="source-icon"><Music size={16} /></div>
                <div className="source-title">Music Demo</div>
                <div className="source-subtitle">Upload a music file to start mixing</div>
              </Link>
            )}

            {podcastUpload ? (
              <div className="source-card" style={{ position: "relative" }}>
                <Link href={`/room/${podcastUpload.id}`} style={{ display: "block", textDecoration: "none" }}>
                  <div
                    className="source-card-bg"
                    style={{
                      backgroundImage: "url('https://images.unsplash.com/photo-1520950335585-0f7c2f58d481?q=80&w=1169&auto=format&fit=crop')",
                      opacity: 0.7,
                    }}
                  />
                  <div className="source-icon"><Radio size={16} /></div>
                  <div className="source-title">Podcast Demo</div>
                  <div className="source-subtitle">{podcastUpload.title} · {podcastUpload.artist}</div>
                </Link>
                <div style={{ position: "absolute", top: 8, right: 8, display: "flex", gap: 4 }}>
                  {podcastUpload.source === "youtube" && (
                    <Cloud size={14} className="text-accent" />
                  )}
                  <a
                    href={podcastUpload.file_url}
                    download
                    title="Download file"
                    style={{ color: "var(--muted)" }}
                    onClick={(e) => e.stopPropagation()}
                  >
                    <Download size={14} />
                  </a>
                </div>
              </div>
            ) : (
              <Link href="/uploads" className="source-card" style={{ opacity: 0.6 }}>
                <div
                  className="source-card-bg"
                  style={{
                    backgroundImage: "url('https://images.unsplash.com/photo-1520950335585-0f7c2f58d481?q=80&w=1169&auto=format&fit=crop')",
                    opacity: 0.4,
                  }}
                />
                <div className="source-icon"><Radio size={16} /></div>
                <div className="source-title">Podcast Demo</div>
                <div className="source-subtitle">Upload a podcast file to start mixing</div>
              </Link>
            )}

            {voiceUpload ? (
              <div className="source-card" style={{ position: "relative" }}>
                <Link href={`/room/${voiceUpload.id}`} style={{ display: "block", textDecoration: "none" }}>
                  <div
                    className="source-card-bg"
                    style={{
                      backgroundImage: "url('https://images.unsplash.com/photo-1602973334375-61f6f274fa8e?q=80&w=1170&auto=format&fit=crop')",
                      opacity: 0.8,
                    }}
                  />
                  <div className="source-icon"><Mic size={16} /></div>
                  <div className="source-title">Voice Demo</div>
                  <div className="source-subtitle">{voiceUpload.title} · {voiceUpload.artist}</div>
                </Link>
                <div style={{ position: "absolute", top: 8, right: 8, display: "flex", gap: 4 }}>
                  {voiceUpload.source === "youtube" && (
                    <Cloud size={14} className="text-accent" />
                  )}
                  <a
                    href={voiceUpload.file_url}
                    download
                    title="Download file"
                    style={{ color: "var(--muted)" }}
                    onClick={(e) => e.stopPropagation()}
                  >
                    <Download size={14} />
                  </a>
                </div>
              </div>
            ) : (
              <Link href="/uploads" className="source-card" style={{ opacity: 0.6 }}>
                <div
                  className="source-card-bg"
                  style={{
                    backgroundImage: "url('https://images.unsplash.com/photo-1602973334375-61f6f274fa8e?q=80&w=1170&auto=format&fit=crop')",
                    opacity: 0.4,
                  }}
                />
                <div className="source-icon"><Mic size={16} /></div>
                <div className="source-title">Voice Demo</div>
                <div className="source-subtitle">Upload a voice file to start mixing</div>
              </Link>
            )}
          </div>

          {/* Recent Sessions */}
          <div className="submissions-panel">
            <div className="section-label">Your Recent Sessions</div>
            {loadingExtras && sessions.length === 0 ? (
              <p style={{ fontSize: "13px", color: "var(--muted)", padding: "8px 0" }}>
                Loading sessions...
              </p>
            ) : sessions.length === 0 ? (
              <p style={{ fontSize: "13px", color: "var(--muted)", padding: "8px 0" }}>
                No sessions yet. Tap a demo above to start testing.
              </p>
            ) : (
              sessions.map((s) => (
                <div
                  key={s.id}
                  className="submission-item"
                  style={{ cursor: "pointer" }}
                  onClick={() => setSelectedSession(s as SessionDetail)}
                >
                  <div className="sub-meta">
                    <h4>{s.song_title}</h4>
                    <p>
                      Enhanced {Math.round(((s.final_settings?.eq298 ?? 0) + 12) / 24 * 100)}%
                      {s.ab_toggles > 0 ? ` · ${s.ab_toggles} A/B toggle${s.ab_toggles === 1 ? "" : "s"}` : ""}
                    </p>
                  </div>
                  <div className="sub-date">
                    {new Date(s.created_at).toLocaleDateString()}
                    <br />
                    {new Date(s.created_at).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}
                  </div>
                </div>
              ))
            )}
          </div>
        </>
      )}

      <SessionDetailModal
        session={selectedSession}
        onClose={() => setSelectedSession(null)}
      />

      <BottomNav />
    </div>
  );
}
