# ──── Database ────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ──── Auth ────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# ──── Backblaze B2 (file storage) ────
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_BUCKET_ID=
# Friendly download URL (e.g. https://f003.backblazeb2.com/file/your-bucket-name)
B2_DOWNLOAD_URL=

# ──── Processing service (Docker on Railway — YouTube download + audio analysis) ────
# Railway URL: https://your-service.up.railway.app
# Leave empty to disable YouTube + auto-analysis features
PROCESSING_SERVICE_URL=

# ──── CORS (processing service only) ────
# Comma-separated list of allowed origins for the processing service
# Not needed on Vercel — only on Railway
CORS_ORIGINS=https://your-app.vercel.app
